# Base LFS behaviors
[attr]lfs     filter=lfs diff=lfs merge=lfs -text
[attr]lock    filter=lfs diff=lfs merge=lfs -text lockable

# Unreal Engine binaries (lock required)
*.uasset lfs
*.umap   lfs
*.ubulk  lfs
*.uexp   lfs
# Other binaries you want to lock (optional; you decide policy)
*.fbx  lfs
*.wav  lfs
*.mp4  lfs
*.png  lfs
*.jpg  lfs
*.tiff lfs
